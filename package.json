{
  "name": "inventario",
  "version": "0.1.0",
  "private": true,
  "description": "Inventario — open-source platforma pre evidenciu a vypožičiavanie majetku. Multi-tenant white-label backend a docs (apps/api, apps/docs, packages/*).",
  "homepage": "https://inventario.sportup.sk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Slovensky-futbalovy-zvaz/Asset-Management.git"
  },
  "bugs": {
    "url": "https://github.com/Slovensky-futbalovy-zvaz/Asset-Management/issues"
  },
  "license": "EUPL-1.2",
  "author": "Ján Letko / LTK Solutions",
  "type": "module",
  "engines": {
    "node": ">=22.20.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml,css}\"",
    "sbom": "pnpm dlx @cyclonedx/cdxgen@^11 -r -t js -o sbom.cdx.json --spec-version 1.6 --no-babel",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/js": "^9.12.0",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^15.11.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.9.14",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml,css}": [
      "prettier --write"
    ]
  }
}
