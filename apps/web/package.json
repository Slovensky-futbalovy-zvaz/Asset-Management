{
  "name": "@inventario/web",
  "version": "0.1.0",
  "private": true,
  "description": "Inventario · Frontend webová aplikácia (inventario.sportup.sk/app). Next.js 15 + TanStack Query + Tailwind + shadcn/ui.",
  "license": "EUPL-1.2",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3001",
    "prebuild": "pnpm generate:api-types",
    "build": "next build",
    "start": "next start --port 3001",
    "prelint": "pnpm generate:api-types",
    "lint": "eslint src --max-warnings 0",
    "pretypecheck": "pnpm generate:api-types",
    "typecheck": "tsc --noEmit",
    "test": "echo 'TODO: vitest + react-testing-library' && exit 0",
    "generate:api-types": "openapi-typescript ../api/openapi.json -o src/lib/api-types.ts",
    "clean": "rm -rf .next .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.10.1",
    "@azure/msal-react": "^5.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@inventario/design-tokens": "workspace:*",
    "@inventario/shared-types": "workspace:*",
    "@tanstack/react-query": "^5.62.7",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "~15.5.0",
    "openapi-fetch": "^0.13.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "openapi-typescript": "^7.4.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.20.0"
  },
  "keywords": [
    "inventario",
    "frontend",
    "nextjs",
    "react",
    "tailwind",
    "multi-tenant"
  ]
}
