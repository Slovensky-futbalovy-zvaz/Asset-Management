# Inventario web — env vars
#
# Copy to `.env.local` and fill in. All values prefixed with NEXT_PUBLIC_
# are baked into the client bundle — they cannot hold secrets, only IDs
# and URLs.

# ----------------------------------------------------------------------
# Backend API
# ----------------------------------------------------------------------
# Where the Fastify backend listens. Dev runs on :3000, production lives
# at https://api.inventario.sportup.sk.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# ----------------------------------------------------------------------
# Microsoft Entra ID — frontend SPA app registration
# ----------------------------------------------------------------------
# The frontend is a SEPARATE Entra app registration from the backend API.
# Create it in Azure Portal → Entra ID → App registrations:
#   - Platform: Single-page application (SPA)
#   - Redirect URI: http://localhost:3001 (dev) and your prod URL
#   - API permissions: add `api://<NEXT_PUBLIC_ENTRA_API_CLIENT_ID>/access_as_user`
#     (the delegated permission exposed by the backend)
#
# Application (client) ID — frontend SPA registration.
NEXT_PUBLIC_ENTRA_CLIENT_ID=

# Directory (tenant) ID — same value as backend ENTRA_TENANT_ID.
NEXT_PUBLIC_ENTRA_TENANT_ID=

# Backend API's Application (client) ID — used to construct the scope
# `api://<this-value>/access_as_user`. Same as backend ENTRA_API_CLIENT_ID.
NEXT_PUBLIC_ENTRA_API_CLIENT_ID=
