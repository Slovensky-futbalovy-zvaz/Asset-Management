# ============================================================================
# SFZ Asset Management — API environment variables
# ============================================================================
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Vercel deployment, set these in:
#   Vercel Dashboard → Project → Settings → Environment Variables
#
# NEVER commit .env.local or .env to git (already in .gitignore).
# ============================================================================

# --- Application ---
# 'development' enables pino-pretty logs, dev-only routes
# 'production' enables strict validation, structured JSON logs
NODE_ENV=development

# Port for local development (Vercel ignores this in production)
PORT=3000

# Log level: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=debug

# --- MongoDB Atlas ---
# Get from: https://cloud.mongodb.com → Cluster → Connect → Drivers
# Format: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://sfz-api:CHANGE_ME@sfz-asset-dev.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database name (will be created automatically on first write)
MONGO_DB_NAME=sfz_asset_management

# --- CORS ---
# Comma-separated list of allowed origins (frontend URLs)
# For local dev: include http://localhost:3001 (apps/web default port)
# For production: https://app.sfz.sk, https://sfz-asset-management.vercel.app
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# --- Auth (Entra ID) ---
# Get these from Azure Portal → Entra ID → App registrations → "SFZ Asset Management API".
#
# ENTRA_TENANT_ID:
#   Directory (tenant) ID — visible on Overview page of any app registration
#   or under Entra ID → Overview. Format: GUID (UUID v4).
#
# ENTRA_API_CLIENT_ID:
#   Application (client) ID of the API app registration (NOT the CLI/SPA client).
#   Format: GUID. The JWT's `aud` claim must equal this value (or `api://<guid>`).
#
# Both required — the server refuses to start without them.
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_API_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Optional overrides — derived automatically from ENTRA_TENANT_ID if omitted.
# Only set these for non-public Azure clouds (e.g. Azure Government).
# ENTRA_ISSUER=https://login.microsoftonline.com/${ENTRA_TENANT_ID}/v2.0
# ENTRA_JWKS_URI=https://login.microsoftonline.com/${ENTRA_TENANT_ID}/discovery/v2.0/keys

# CLI app client ID — ONLY used by scripts/dev-auth-test.sh for fetching
# test tokens via device code flow. NOT consumed by the API server itself.
# Create a separate public-client app registration in Azure for this.
# ENTRA_CLI_CLIENT_ID=00000000-0000-0000-0000-000000000000

# --- Feature flags ---
# Enable Swagger UI at /docs (recommended for dev/staging, disable for prod)
ENABLE_SWAGGER=true
