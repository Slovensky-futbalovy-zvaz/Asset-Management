{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "allowJs": false,
    "noEmit": true
  },
  "include": ["./index.ts", "../src/**/*.ts"]
}
