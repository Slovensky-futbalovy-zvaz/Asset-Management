{
  "name": "@inventario/api",
  "version": "0.1.0",
  "private": true,
  "description": "Inventario — Fastify backend API. Multi-tenant asset management platform. Deployed on Vercel Serverless Functions.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env.local src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env.local dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.eslint.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "migrate:organisation-id": "tsx --env-file-if-exists=.env.local scripts/migrate-organisation-id.ts",
    "openapi:export": "tsx --env-file-if-exists=.env.local scripts/export-openapi.ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.4",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.1.0",
    "@inventario/shared-types": "workspace:*",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "get-jwks": "^11.0.0",
    "jose": "^5.9.6",
    "mongodb": "^6.10.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=22.20.0"
  },
  "keywords": [
    "inventario",
    "fastify",
    "backend",
    "api",
    "multi-tenant"
  ],
  "license": "EUPL-1.2"
}
