# =============================================================================
# SFZ Asset Management — Environment Variables (Template)
# =============================================================================
#
# 1. Skopíruj tento súbor ako `.env` v koreni repa
#    cp .env.example .env
# 2. Vyplň skutočné hodnoty (NIKDY ich nedávaj do gitu!)
# 3. Pre produkciu používaj secrets management (Azure Key Vault, AWS Secrets, ...)
# =============================================================================


# ─────────────────────────────────────────────────────────────────────
# General
# ─────────────────────────────────────────────────────────────────────

NODE_ENV=development                                # development | test | production
LOG_LEVEL=debug                                     # debug | info | warn | error


# ─────────────────────────────────────────────────────────────────────
# MongoDB (lokál cez docker-compose)
# ─────────────────────────────────────────────────────────────────────

MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme-local-only
MONGO_URI=mongodb://admin:changeme-local-only@localhost:27017/sfz_asset_management?authSource=admin
MONGO_DB_NAME=sfz_asset_management

# Pre produkciu (MongoDB Atlas):
# MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/sfz_asset_management?retryWrites=true&w=majority


# ─────────────────────────────────────────────────────────────────────
# API server (apps/api)
# ─────────────────────────────────────────────────────────────────────

API_PORT=3001
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000


# ─────────────────────────────────────────────────────────────────────
# Web app (apps/web — Next.js)
# ─────────────────────────────────────────────────────────────────────

WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME="SFZ Asset Management"


# ─────────────────────────────────────────────────────────────────────
# Microsoft Entra ID (Azure AD) — Auth
# ─────────────────────────────────────────────────────────────────────

ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:3000/api/auth/callback/entra


# ─────────────────────────────────────────────────────────────────────
# JWT (pre internú reláciu po Entra ID prihlásení a pre externých)
# ─────────────────────────────────────────────────────────────────────

JWT_SECRET=replace-with-256-bit-random-string-in-production
JWT_ISSUER=sfz-asset-management
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d


# ─────────────────────────────────────────────────────────────────────
# Object storage (lokál: MinIO, prod: Azure Blob)
# ─────────────────────────────────────────────────────────────────────

STORAGE_PROVIDER=minio                              # minio | azure-blob | s3
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=changeme-local-only
STORAGE_BUCKET_ATTACHMENTS=sfz-asset-attachments
STORAGE_BUCKET_PROTOCOLS=sfz-asset-protocols
STORAGE_REGION=us-east-1                            # Pre MinIO nezáleží, ale S3 vyžaduje


# ─────────────────────────────────────────────────────────────────────
# E-mail (lokál: MailHog, prod: SendGrid alebo Microsoft Graph)
# ─────────────────────────────────────────────────────────────────────

MAIL_PROVIDER=smtp                                  # smtp | sendgrid | graph
MAIL_FROM_ADDRESS=noreply@futbalsfz.sk
MAIL_FROM_NAME="SFZ Asset Management"
MAIL_SMTP_HOST=localhost
MAIL_SMTP_PORT=1025
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_SECURE=false


# ─────────────────────────────────────────────────────────────────────
# MCP server (apps/mcp-server)
# ─────────────────────────────────────────────────────────────────────

MCP_PORT=3002
MCP_PAT_SECRET=replace-with-random-string           # Pre lokálne Personal Access Tokens


# ─────────────────────────────────────────────────────────────────────
# Observability (TODO: setup OpenTelemetry)
# ─────────────────────────────────────────────────────────────────────

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=sfz-asset-management
