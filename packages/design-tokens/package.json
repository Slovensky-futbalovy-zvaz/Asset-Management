{
  "name": "@inventario/design-tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Inventario design tokens — single source of truth pre brand farby, typografiu, spacing a multi-tenant white-label overrides.",
  "license": "EUPL-1.2",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tokens.json": "./tokens.json",
    "./tokens.css": "./src/tokens.css",
    "./tailwind": "./src/tailwind-preset.js",
    "./brand-kit.schema.json": "./src/brand-kit.schema.json"
  },
  "files": [
    "dist",
    "src/tokens.css",
    "src/tailwind-preset.js",
    "src/brand-kit.schema.json",
    "tokens.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'TODO: snapshot test of tokens.json schema'",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "inventario",
    "design-tokens",
    "design-system",
    "multi-tenant",
    "white-label",
    "brand"
  ],
  "publishConfig": {
    "access": "restricted"
  }
}
