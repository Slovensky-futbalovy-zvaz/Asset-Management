{
  "$schema": "https://schemas.tokens.studio/v1",
  "$description": "Inventario design tokens. 3-vrstvová architektúra: Primitives → Semantic → Brand. Primitives sú raw hodnoty, Semantic dáva im význam (success, danger, surface), Brand je default Inventario layer ktorý sa overridje per-tenant. Multi-tenant pattern: :root[data-tenant='X'] override iba brand vrstvy.",
  "$version": "0.2.0",
  "$source": "BRAND.md v1.0 (post-pivot, 2026-05-15)",

  "$comment-layers": "VRSTVY: (1) primitive.* — raw hex/values, nikdy nie referenced v UI priamo. (2) semantic.* — UI rola (text, surface, success, …), referncuje primitive. (3) brand.* — Inventario default identita, referncuje primitive a override-uje sa per-tenant.",

  "primitive": {
    "$description": "Raw hodnoty. NIKDY ich nepoužívaj priamo v komponentoch — vždy cez semantic alebo brand vrstvu. Mení sa len keď dáme do palety nové hodnoty.",

    "color": {
      "navy": {
        "50": { "value": "#f0f2f6", "type": "color" },
        "100": { "value": "#d8dde7", "type": "color" },
        "300": { "value": "#7e8da7", "type": "color" },
        "500": { "value": "#3e577a", "type": "color" },
        "700": {
          "value": "#1a2d47",
          "type": "color",
          "description": "Inventario Navy — primary brand color"
        },
        "900": {
          "value": "#0e1a2b",
          "type": "color",
          "description": "Darkest navy, used for dark mode surfaces"
        }
      },
      "blue": {
        "50": { "value": "#eaf3fa", "type": "color" },
        "100": { "value": "#c5dff0", "type": "color" },
        "300": { "value": "#7dbae0", "type": "color" },
        "500": {
          "value": "#388fc3",
          "type": "color",
          "description": "Inventario Blue — accent color"
        },
        "700": { "value": "#1f6fa0", "type": "color" },
        "900": { "value": "#103a55", "type": "color" }
      },
      "paper": {
        "50": { "value": "#fdfcfa", "type": "color" },
        "100": {
          "value": "#f8f6f1",
          "type": "color",
          "description": "Inventario Paper — page background"
        },
        "200": { "value": "#ecebe5", "type": "color" }
      },
      "steel": {
        "300": { "value": "#9aa5b5", "type": "color" },
        "500": {
          "value": "#6b7a8d",
          "type": "color",
          "description": "Inventario Steel — muted text"
        },
        "700": { "value": "#4a5566", "type": "color" }
      },
      "white": { "value": "#ffffff", "type": "color" },
      "black": {
        "value": "#070504",
        "type": "color",
        "description": "True black, used sparingly (shadows, OCR codes). Prefer navy.900 for UI."
      },
      "gray": {
        "100": { "value": "#f3f4f6", "type": "color" },
        "200": { "value": "#e5e7eb", "type": "color" },
        "300": { "value": "#d1d5db", "type": "color" },
        "500": { "value": "#9ca3af", "type": "color" },
        "700": { "value": "#4b5563", "type": "color" }
      },
      "emerald": { "value": "#10b981", "type": "color", "description": "Success indicator" },
      "amber": { "value": "#f59e0b", "type": "color", "description": "Warning indicator" },
      "rose": { "value": "#ef4444", "type": "color", "description": "Danger / error indicator" }
    },

    "font": {
      "family": {
        "sans": {
          "value": "'Poppins', system-ui, -apple-system, sans-serif",
          "type": "fontFamily",
          "description": "Inventario UI typeface. Poppins má dynamic italic ktorý je súčasťou wordmark."
        },
        "mono": {
          "value": "'JetBrains Mono', 'Menlo', monospace",
          "type": "fontFamily",
          "description": "Technické labels, inventárne čísla, kód."
        }
      },
      "weight": {
        "regular": { "value": 400, "type": "fontWeight" },
        "medium": { "value": 500, "type": "fontWeight" },
        "semibold": { "value": 600, "type": "fontWeight" },
        "bold": { "value": 700, "type": "fontWeight" },
        "extrabold": {
          "value": 800,
          "type": "fontWeight",
          "description": "Wordmark only — Poppins ExtraBold Italic"
        }
      }
    },

    "spacing": {
      "$description": "4px grid base. Pomenované numericky aby Tailwind mapping bol triviálny (spacing-4 → 1rem).",
      "0": { "value": "0", "type": "spacing" },
      "1": { "value": "0.25rem", "type": "spacing" },
      "2": { "value": "0.5rem", "type": "spacing" },
      "3": { "value": "0.75rem", "type": "spacing" },
      "4": { "value": "1rem", "type": "spacing" },
      "5": { "value": "1.25rem", "type": "spacing" },
      "6": { "value": "1.5rem", "type": "spacing" },
      "8": { "value": "2rem", "type": "spacing" },
      "10": { "value": "2.5rem", "type": "spacing" },
      "12": { "value": "3rem", "type": "spacing" },
      "16": { "value": "4rem", "type": "spacing" },
      "20": { "value": "5rem", "type": "spacing" },
      "24": { "value": "6rem", "type": "spacing" }
    },

    "radius": {
      "$description": "Border radius scale. Hodnoty pochádzajú z BRAND.md §2 (buttons 10px, cards 16px, inputs 10px, badges pill).",
      "none": { "value": "0", "type": "borderRadius" },
      "sm": { "value": "0.25rem", "type": "borderRadius" },
      "md": { "value": "0.5rem", "type": "borderRadius" },
      "lg": {
        "value": "0.625rem",
        "type": "borderRadius",
        "description": "10px — buttons & inputs (BRAND.md spec)"
      },
      "xl": {
        "value": "1rem",
        "type": "borderRadius",
        "description": "16px — cards (BRAND.md spec)"
      },
      "full": { "value": "9999px", "type": "borderRadius", "description": "Pills, badges, avatars" }
    },

    "shadow": {
      "$description": "Subtle navy-based shadows. NIKDY čistá čierna — vždy navy.700 s opacity. Pochádzajú z BRAND.md §2.",
      "sm": {
        "value": "0 1px 2px 0 rgba(26, 45, 71, 0.06)",
        "type": "boxShadow"
      },
      "md": {
        "value": "0 2px 6px rgba(26, 45, 71, 0.12)",
        "type": "boxShadow",
        "description": "Default elevation (cards at rest)"
      },
      "lg": {
        "value": "0 10px 30px -8px rgba(26, 45, 71, 0.12)",
        "type": "boxShadow",
        "description": "Hover elevation (cards on hover)"
      },
      "cta": {
        "value": "0 4px 14px color-mix(in srgb, var(--inv-brand-primary) 25%, transparent)",
        "type": "boxShadow",
        "description": "CTA emphasis — uses CSS color-mix with current brand"
      }
    }
  },

  "semantic": {
    "$description": "UI-role tokeny. Komponent vždy číta semantic, nikdy primitive. Tým že semantic referencuje primitive, vrstvy sú vymeniteľné nezávisle (napr. dark mode mení semantic.surface, primitive zostáva).",

    "color": {
      "text": {
        "primary": {
          "value": "{primitive.color.navy.700.value}",
          "type": "color",
          "description": "Hlavný text, headings"
        },
        "secondary": {
          "value": "{primitive.color.steel.500.value}",
          "type": "color",
          "description": "Captions, helper text"
        },
        "muted": {
          "value": "{primitive.color.steel.300.value}",
          "type": "color",
          "description": "Placeholder, disabled"
        },
        "inverse": {
          "value": "{primitive.color.white.value}",
          "type": "color",
          "description": "Text na tmavom pozadí"
        },
        "link": { "value": "{primitive.color.blue.500.value}", "type": "color" },
        "link-hover": { "value": "{primitive.color.blue.700.value}", "type": "color" }
      },
      "surface": {
        "page": {
          "value": "{primitive.color.paper.100.value}",
          "type": "color",
          "description": "Body background"
        },
        "card": { "value": "{primitive.color.white.value}", "type": "color" },
        "elevated": {
          "value": "{primitive.color.white.value}",
          "type": "color",
          "description": "Modals, dropdowns"
        },
        "subtle": {
          "value": "{primitive.color.paper.50.value}",
          "type": "color",
          "description": "Subtle hover, alt rows"
        },
        "inverse": {
          "value": "{primitive.color.navy.700.value}",
          "type": "color",
          "description": "Dark sections, footers"
        }
      },
      "border": {
        "subtle": { "value": "{primitive.color.gray.200.value}", "type": "color" },
        "default": { "value": "{primitive.color.gray.300.value}", "type": "color" },
        "strong": { "value": "{primitive.color.steel.500.value}", "type": "color" },
        "focus": {
          "value": "{primitive.color.blue.500.value}",
          "type": "color",
          "description": "Keyboard focus outline"
        }
      },
      "success": {
        "fg": { "value": "{primitive.color.emerald.value}", "type": "color" },
        "bg": {
          "value": "color-mix(in srgb, var(--inv-primitive-emerald) 10%, transparent)",
          "type": "color"
        }
      },
      "warning": {
        "fg": { "value": "{primitive.color.amber.value}", "type": "color" },
        "bg": {
          "value": "color-mix(in srgb, var(--inv-primitive-amber) 12%, transparent)",
          "type": "color"
        }
      },
      "danger": {
        "fg": { "value": "{primitive.color.rose.value}", "type": "color" },
        "bg": {
          "value": "color-mix(in srgb, var(--inv-primitive-rose) 10%, transparent)",
          "type": "color"
        }
      },
      "info": {
        "fg": { "value": "{primitive.color.blue.500.value}", "type": "color" },
        "bg": {
          "value": "color-mix(in srgb, var(--inv-primitive-blue-500) 10%, transparent)",
          "type": "color"
        }
      }
    },

    "asset-status": {
      "$description": "Farby pre AssetStatus enum (zhodné s backend dátovým modelom).",
      "available": { "value": "{primitive.color.emerald.value}", "type": "color" },
      "reserved": { "value": "{primitive.color.amber.value}", "type": "color" },
      "borrowed": { "value": "{primitive.color.blue.500.value}", "type": "color" },
      "in-service": { "value": "{primitive.color.amber.value}", "type": "color" },
      "disposed": { "value": "{primitive.color.steel.500.value}", "type": "color" },
      "lost": { "value": "{primitive.color.rose.value}", "type": "color" }
    }
  },

  "brand": {
    "$description": "Inventario default brand vrstva. TOTO je to čo sa override-uje per-tenant (cez :root[data-tenant='X'] selector). Komponenty čítajú brand.* keď chcú primárnu farbu — semantic.* keď chcú UI rolu.",

    "primary": {
      "value": "{primitive.color.navy.700.value}",
      "type": "color",
      "description": "Inventario default: Navy. Tenant override: napr. Bratislava modrá #003d7a."
    },
    "primary-fg": {
      "value": "{primitive.color.white.value}",
      "type": "color",
      "description": "Foreground pre brand.primary background"
    },
    "accent": {
      "value": "{primitive.color.blue.500.value}",
      "type": "color",
      "description": "Inventario default: Blue. Tenant override: napr. Bratislava zlatá #FFD700."
    },
    "accent-fg": {
      "value": "{primitive.color.white.value}",
      "type": "color"
    },
    "logo-dot": {
      "value": "{primitive.color.blue.500.value}",
      "type": "color",
      "description": "Accent dot v logu. Per BRAND.md NIKDY sa nemení na inú farbu ako #388fc3, ale tenant si môže override-nuť ak má vlastné logo."
    }
  },

  "wordmark": {
    "$description": "Inventario wordmark má fixné styling parametre per BRAND.md §5. Nie token v zmysle vymeniteľnosti, ale uložené tu pre konzistentné použitie.",
    "fontFamily": { "value": "{primitive.font.family.sans.value}", "type": "fontFamily" },
    "fontWeight": { "value": "{primitive.font.weight.extrabold.value}", "type": "fontWeight" },
    "fontStyle": { "value": "italic", "type": "fontStyle" },
    "letterSpacing": { "value": "-0.02em", "type": "letterSpacing" }
  }
}
